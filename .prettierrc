{
	"singleQuote": true,
	"printWidth": 250,
	"editor.formatOnSave": true,
	"proseWrap": "always",
	"tabWidth": 2,
	"requireConfig": false,
	"useTabs": true,
	"trailingComma": "none",
	"bracketSpacing": true,
	"jsxBracketSameLine": false,
	"semi": false,
	"overrides": [
		{
			"files": ["**/*.css", "**/*.scss", "**/*.html"],
			"options": {
				"singleQuote": false
			}
		}
	]
}
